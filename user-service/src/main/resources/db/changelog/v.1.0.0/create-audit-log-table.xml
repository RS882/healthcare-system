<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="create_audit_log_table" author="RsLan">

        <createTable tableName="audit_log">

            <column name="id"
                    type="BIGINT"
                    autoIncrement="true">
                <constraints primaryKey="true"
                             primaryKeyName="pk_audit_log"
                             nullable="false"/>
            </column>

            <column name="event_id"
                    type="CHAR(36)">
                <constraints nullable="false"
                             unique="true"
                             uniqueConstraintName="uk_audit_log_event_id"/>
            </column>

            <column name="event_type"
                    type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="aggregate_type"
                    type="VARCHAR(100)"/>

            <column name="aggregate_id"
                    type="VARCHAR(100)"/>

            <column name="message"
                    type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>

            <column name="payload"
                    type="TEXT"/>

            <column name="created_at"
                    type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

        </createTable>

        <createIndex indexName="idx_audit_log_created_at"
                     tableName="audit_log">
            <column name="created_at"/>
        </createIndex>

        <createIndex indexName="idx_audit_log_event_type"
                     tableName="audit_log">
            <column name="event_type"/>
        </createIndex>

        <createIndex indexName="idx_audit_log_aggregate"
                     tableName="audit_log">
            <column name="aggregate_type"/>
            <column name="aggregate_id"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>